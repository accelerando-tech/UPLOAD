MINT_FEE_ETH=0.001
CHAIN=baseSepolia
BASE_RPC_URL=https://sepolia.base.org

# Contract (after deploy)
AGENT_PFP_CONTRACT=
MINTER_PRIVATE_KEY=
TREASURY_ADDRESS=
